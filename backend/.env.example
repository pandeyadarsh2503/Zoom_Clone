# ── Backend environment ───────────────────────────────────────
# Copy to `.env` for local dev. In production set these as real env vars
# in Railway/Render (never commit a real .env).

# Application
APP_NAME=Zoom Clone API
APP_VERSION=0.1.0
ENVIRONMENT=development            # development | production
DEBUG=false

# Server — managed hosts inject PORT automatically; leave unset there.
HOST=0.0.0.0
PORT=8000

# Database
# Local (default):
DATABASE_URL=sqlite:///./zoom_clone.db
# Production (Railway/Render Postgres) — a "postgres://" URL is auto-normalized:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth — MUST be a long random string in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRES_SECONDS=604800        # 7 days

# CORS — the exact origin(s) of your deployed frontend (no trailing slash).
# JSON array or comma-separated.
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Frontend base URL — used to build shareable invite links.
FRONTEND_URL=http://localhost:3000

# Seeded demo account
DEMO_EMAIL=demo@zoom.clone
DEMO_PASSWORD=demo1234

# Default seeded user
DEFAULT_USER_DISPLAY_NAME=Default User
DEFAULT_USER_AVATAR_URL=
