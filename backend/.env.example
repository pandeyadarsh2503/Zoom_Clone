# ── Application ───────────────────────────────────────────────
APP_NAME=Zoom Clone API
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./zoom_clone.db

# ── CORS ──────────────────────────────────────────────────────
# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Default User (seeded on first startup) ────────────────────
DEFAULT_USER_DISPLAY_NAME=Default User
DEFAULT_USER_AVATAR_URL=
